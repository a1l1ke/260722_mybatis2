<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.mybatis2.mapper.UserAccountMapper">
    <insert id="create" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO USERS
        (name, email, age, city)
        VALUES
        (#{name}, #{email}, #{age}, #{city})
    </insert>
    <!--  SELECT id, ... FROM USERS  -->
    <select id="findAll" resultType="org.example.mybatis2.entity.UserAccount">
        SELECT * FROM USERS
    </select>
</mapper>